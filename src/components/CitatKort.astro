---
import CtaKnap from "./CtaKnap.astro";

interface Props {
  overskrift: string;
  tekst1: string;
  citat: string;
  tekst2: string;
}

const { overskrift, tekst1, citat, tekst2 } = Astro.props;
---

<section class="citat-sektion">
  <div class="container">
    <div class="citat-kort">
      <!-- Gult papir øverst til venstre -->
      <img src="/images/collage/papir-gul.png" alt="" class="papir-gul" aria-hidden="true" />

      <!-- Hvidt papirstykke i midten som baggrund -->
      <img src="/images/collage/papirstykke-hvid.png" alt="" class="papirstykke-hvid" aria-hidden="true" />

      <!-- Tekst ovenpå -->
      <div class="citat-indhold">
        <p class="citat-overskrift">{overskrift}</p>
        <p class="citat-tekst">{tekst1}</p>
        <p class="citat-tekst kursiv">{citat}</p>
        <p class="citat-tekst">{tekst2}</p>
      </div>

      <!-- Hvidt papir nederst -->
      <img src="/images/collage/papir-hvid.png" alt="" class="papir-hvid" aria-hidden="true" />
      <div class="knap-wrapper">
        <CtaKnap tekst="Sådan bestiller du Dankort" popupId="popup" />
      </div>
    </div>
  </div>
</section>

<style>
  /* =====================
     MOBILE FIRST
     ===================== */

  .citat-sektion {
    padding: 5rem 0 3rem;
    background-color: var(--hvid);
    overflow: hidden;
  }

  .citat-kort {
    position: relative;
    max-width: 400px;
  }

  /* Gult papir — øverst til venstre */
  .papir-gul {
    position: absolute;
    top: 1rem;
    left: -5rem;
    width: 300px;
    height: auto;
    z-index: 1;
  }

  /* Hvidt papirstykke — bagved teksten */
  .papirstykke-hvid {
    position: absolute;
    top: 6rem;
    left: -8%;
    width: 160%;
    height: auto;
    z-index: 0;
  }

  /* Tekst — øverst i stakken */
  .citat-indhold {
    position: relative;
    z-index: 2;
    padding: 3rem 1rem 4rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .citat-overskrift {
    font-size: 1.4rem;
    font-weight: 800;
    line-height: 1.4;
  }

  .citat-tekst {
    font-size: 0.9rem;
  }

  .kursiv {
    font-style: italic;
  }

  .papir-hvid {
    position: relative;
    width: 110%;
    margin-left: -1rem;
    margin-top: -14rem;
    z-index: 1;
  }

  .knap-wrapper {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 3;
    white-space: nowrap;
  }

  /* =====================
     DESKTOP (1024px+)
     ===================== */

  @media (min-width: 1024px) {
    .citat-sektion {
      padding: 4rem 0;
    }

    .citat-kort {
      max-width: 1000px;
    }

    .papir-gul {
      width: 300px;
      top: -5rem;
      left: 12rem;
    }

    .papirstykke-hvid {
      width: 900px;
      top: -2rem;
      left: 15rem;
    }

    .papir-hvid {
      width: 300px;
      margin-left: 60rem;
      margin-top: -14rem;
    }

    .citat-indhold {
      padding: 3.5rem 2rem 5rem;
      margin-left: 19rem;
      margin-top: 0;
    }

    .citat-overskrift {
      font-size: 2rem;
    }

    .citat-tekst {
      font-size: 1rem;
    }
  }
</style>
