---
import CtaKnap from "./CtaKnap.astro";

interface Props {
  overskrift: string;
  tekst1: string;
  citat: string;
  tekst2: string;
}

const { overskrift, tekst1, citat, tekst2 } = Astro.props;
---

<section class="citat-sektion slide-hoejre" aria-label="Citat og information om Dankort Øremærket">
  <div class="container">
    <div class="citat-kort">
      <img src="/images/collage/papir-gul.webp" alt="" class="papir-gul" aria-hidden="true" role="presentation" />
      <img src="/images/collage/papirstykke-hvid.webp" alt="" class="papirstykke-hvid" aria-hidden="true" role="presentation" />

      <div class="citat-indhold">
        <h2 class="citat-overskrift">{overskrift}</h2>
        <p class="citat-tekst">{tekst1}</p>
        <p class="citat-tekst kursiv">{citat}</p>
        <p class="citat-tekst">{tekst2}</p>
      </div>

      <div class="knap-wrapper">
        <CtaKnap tekst="Sådan bestiller du Dankort" popupId="popup" />
      </div>

      <img src="/images/collage/papir-hvid.webp" alt="" class="papir-hvid" aria-hidden="true" role="presentation" />
    </div>
  </div>
</section>

<style>
  .citat-sektion {
    padding: 4rem 0 3rem;
    background-color: var(--hvid);
    overflow: hidden;
  }

  .citat-kort {
    position: relative;
    max-width: 400px;
  }

  .papir-gul {
    position: absolute;
    top: 1rem;
    left: -5rem;
    width: 300px;
    height: auto;
    z-index: 1;
    pointer-events: none;
  }

  .papirstykke-hvid {
    position: absolute;
    top: 6rem;
    left: -8%;
    width: 160%;
    height: auto;
    z-index: 0;
    pointer-events: none;
  }

  .citat-indhold {
    position: relative;
    z-index: 2;
    padding: 3rem 1rem 4rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .citat-tekst {
    font-size: 0.9rem;
    font-weight: 800;
  }

  .papir-hvid {
    position: relative;
    width: 110%;
    margin-left: -1rem;
    margin-top: -18rem;
    z-index: 1;
    pointer-events: none;
  }

  .knap-wrapper {
    position: relative;
    display: flex;
    justify-content: center;
    z-index: 3;
    margin-top: 0.5rem;
    padding-bottom: 2rem;
  }

  .citat-overskrift {
    font-size: 1.4rem;
    line-height: 1.4;
    animation: jello 2s ease-in-out infinite;
  }

  @keyframes jello {
    0%,
    11.1%,
    100% {
      transform: none;
    }
    22.2% {
      transform: skewX(-12.5deg) skewY(-12.5deg);
    }
    33.3% {
      transform: skewX(6.25deg) skewY(6.25deg);
    }
    44.4% {
      transform: skewX(-3.125deg) skewY(-3.125deg);
    }
    55.5% {
      transform: skewX(1.5625deg) skewY(1.5625deg);
    }
    66.6% {
      transform: skewX(-0.78125deg) skewY(-0.78125deg);
    }
    77.7% {
      transform: skewX(0.390625deg) skewY(0.390625deg);
    }
    88.8% {
      transform: skewX(-0.1953125deg) skewY(-0.1953125deg);
    }
  }

  @media (min-width: 1024px) {
    .citat-sektion {
      padding: 4rem 0;
    }

    .citat-kort {
      max-width: 1000px;
    }

    .papir-gul {
      width: 300px;
      top: -5rem;
      left: 12rem;
    }

    .papirstykke-hvid {
      width: 900px;
      top: -2rem;
      left: 15rem;
    }

    .papir-hvid {
      width: 300px;
      margin-left: 58rem;
      margin-top: -20rem;
    }

    .citat-indhold {
      padding: 3.5rem 2rem 5rem;
      margin-left: 19rem;
      margin-top: 0;
    }

    .citat-overskrift {
      font-size: 2rem;
    }

    .citat-tekst {
      font-size: 1rem;
    }
  }
</style>
