---
interface Props {
  tekst: string;
  href?: string;
  type?: "button" | "submit";
  popupId?: string;
  id?: string;
  rel?: string;
  target?: string;
}

const { tekst, href, type = "button", popupId, id, rel, target } = Astro.props;
---

{
  href ? (
    <a href={href} id={id} rel={rel} target={target} class="cta-knap">
      <span>{tekst}</span>
      <slot />
    </a>
  ) : (
    <button type={type} id={id} class="cta-knap" data-popup={popupId}>
      <span>{tekst}</span>
      <slot />
    </button>
  )
}

<script>
  document.querySelectorAll("[data-popup]").forEach((knap) => {
    knap.addEventListener("click", () => {
      const id = knap.getAttribute("data-popup");
      if (id) {
        document.getElementById(id)?.classList.add("aaben");
      }
    });
  });
</script>

<style>
  .cta-knap {
    display: inline-flex;
    gap: 0.25rem;
    width: auto;
    align-items: center;
    justify-content: center;
    background: rgba(161, 234, 172, 0.4);
    border: 2px solid var(--limegroen-mork);
    color: var(--sort);
    padding: 0.6rem 1.25rem;
    border-radius: 999px;
    font-family: var(--font-body);
    font-weight: 800;
    font-size: 0.95rem;
    cursor: pointer;
    text-decoration: none;
    text-align: center;
  }
</style>
