---

---

<section class="hero">
  <div class="video-wrapper">
    <video autoplay muted loop playsinline preload="none" id="hero-video-mobil" class="hero-video mobil-video">
      <source src="/video/hero-mobil.mp4" type="video/mp4" />
    </video>

    <video autoplay muted loop playsinline preload="none" id="hero-video-desktop" class="hero-video desktop-video">
      <source src="/video/hero-desktop.mp4" type="video/mp4" />
    </video>

    <h1 class="hero-tekst">
      Mød Dankort <span class="display">Øremærkets</span><br />nye ambassadør
    </h1>

    <div class="video-kontroller">
      <button class="video-knap" id="play-pause" aria-label="Pause video">
        <span id="ikon">⏸</span>
      </button>

      <button class="video-knap lyd-knap" id="lyd-knap" aria-label="Slå lyd til">
        <!-- Muted-ikon: vises som standard (video starter muted) -->
        <svg id="ikon-muted" xmlns="http://www.w3.org/2000/svg" height="22px" viewBox="0 -960 960 960" width="22px" fill="currentColor">
          <path d="m616-320-56-56 104-104-104-104 56-56 104 104 104-104 56 56-104 104 104 104-56 56-104-104-104 104Zm-496-40v-240h160l200-200v640L280-360H120Zm280-246-86 86H200v80h114l86 86v-252ZM300-480Z"></path>
        </svg>
        <!-- Lyd-til-ikon: skjult som standard -->
        <svg id="ikon-lyd" xmlns="http://www.w3.org/2000/svg" height="22px" viewBox="0 -960 960 960" width="22px" fill="currentColor" style="display:none;">
          <path
            d="M560-131v-82q90-26 145-100t55-168q0-94-55-168T560-749v-82q124 28 202 125.5T840-481q0 127-78 224.5T560-131ZM120-360v-240h160l200-200v640L280-360H120Zm440 40v-322q47 22 73.5 66t26.5 96q0 51-26.5 94.5T560-320ZM400-606l-86 86H200v80h114l86 86v-252ZM300-480Z"
          ></path>
        </svg>
      </button>
    </div>
  </div>
</section>

<style>
  .hero-tekst {
    position: absolute;
    top: 2rem;
    left: 2rem;
    line-height: 1.2;
    color: var(--sort);
    z-index: 1;
  }

  .hero {
    display: flex;
    flex-direction: column;
  }

  .video-wrapper {
    position: relative;
    width: 100%;
    height: 100svh;
    background-color: var(--sort);
    overflow: hidden;
  }

  .hero-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .mobil-video {
    display: block;
  }
  .desktop-video {
    display: none;
  }

  @media (min-width: 1024px) {
    .mobil-video {
      display: none;
    }
    .desktop-video {
      display: block;
    }
  }

  .video-kontroller {
    position: absolute;
    bottom: 1.5rem;
    right: 1.5rem;
    display: flex;
    gap: 0.75rem;
    z-index: 2;
  }

  .video-knap {
    background: transparent;
    border: 2px solid var(--solsikkegul-mork);
    color: var(--solsikkegul-mork); /* styrer fill="currentColor" på SVG */
    border-radius: 50%;
    width: 45px;
    height: 45px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition:
      color 0.2s,
      border-color 0.2s;
  }

  /* Aktiv tilstand — når lyd er slået til */
  .video-knap.lyd-aktiv {
    color: var(--solsikkegul-aktiv);
    border-color: var(--solsikkegul-aktiv);
  }

  .video-knap.spiller-aktiv {
    color: var(--solsikkegul-aktiv);
    border-color: var(--solsikkegul-aktiv);
  }
</style>

<script>
  function getAktivVideo(): HTMLVideoElement {
    const erDesktop = window.matchMedia("(min-width: 1024px)").matches;
    return document.getElementById(erDesktop ? "hero-video-desktop" : "hero-video-mobil") as HTMLVideoElement;
  }

  const playKnap = document.getElementById("play-pause");
  const ikon = document.getElementById("ikon");
  const lydKnap = document.getElementById("lyd-knap");
  const ikonMuted = document.getElementById("ikon-muted");
  const ikonLyd = document.getElementById("ikon-lyd");

  playKnap?.addEventListener("click", () => {
    const video = getAktivVideo();
    if (video.paused) {
      video.play();
      if (ikon) ikon.textContent = "⏸";
      playKnap.classList.remove("spiller-aktiv"); // spiller → mørk
    } else {
      video.pause();
      if (ikon) ikon.textContent = "▶";
      playKnap.classList.add("spiller-aktiv"); // pauset → brun
    }
  });

  lydKnap?.addEventListener("click", () => {
    const video = getAktivVideo();
    if (video.muted) {
      video.muted = false;
      ikonMuted!.style.display = "none";
      ikonLyd!.style.display = "block";
      lydKnap!.classList.add("lyd-aktiv");
      lydKnap!.setAttribute("aria-label", "Slå lyd fra");
    } else {
      video.muted = true;
      ikonMuted!.style.display = "block";
      ikonLyd!.style.display = "none";
      lydKnap!.classList.remove("lyd-aktiv");
      lydKnap!.setAttribute("aria-label", "Slå lyd til");
    }
  });
</script>
