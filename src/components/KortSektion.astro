<style>
  .kort-sektion {
    margin-top: 3rem;
  }

  .kort-header {
    padding: 1.5rem 1rem;
    background-color: #fdf6e3;
    margin-bottom: 1rem;
  }

  h2 {
    font-size: 1.8rem;
    font-weight: 800;
    margin-bottom: 0.75rem;
  }

  p {
    font-size: 0.9rem;
    line-height: 1.6;
    margin-bottom: 1rem;
  }

  .filter-knapper {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .filter-knap {
    padding: 0.4rem 1rem;
    border-radius: 999px;
    border: 2px solid var(--naturgroen-mork);
    background: var(--naturgroen);
    color: var(--sort);
    font-family: var(--font-body);
    font-weight: 800;
    font-size: 0.85rem;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .filter-knap.aktiv {
    background-color: var(--solsikkegul-lys);
    color: var(--sort);
    border: 2px solid var(--solsikkegul-aktiv);
  }

  .kort-container {
    position: relative;
    width: 100%;
  }

  #danmarkskort {
    width: 100%;
    height: auto;
    display: block;
  }

  .region-path {
    fill: var(--naturgroen);
    cursor: pointer;
    transition:
      fill 0.3s ease,
      opacity 0.3s ease;
    pointer-events: all;
  }

  .region-path:hover {
    fill: var(--naturgroen-mork);
  }

  .region-path.tonet {
    opacity: 0.3;
  }

  .region-path.aktiv-region {
    fill: var(--naturgroen-mork);
  }

  .natursted-prik {
    cursor: pointer;
    transition:
      opacity 0.3s ease,
      r 0.2s ease;
    pointer-events: all;
  }

  .natursted-prik:hover {
    r: 14;
  }

  .natursted-prik.skjult {
    display: none;
  }

  :global(.tooltip) {
    position: fixed;
    background: var(--hvid);
    border: 2px solid var(--naturgroen);
    border-radius: 0.5rem;
    padding: 0.4rem 0.75rem;
    font-size: 0.85rem;
    font-family: var(--font-body);
    pointer-events: none;
    z-index: 9999;
    opacity: 0;
    transition: opacity 0.2s ease;
    white-space: nowrap;
  }

  :global(.tooltip.synlig) {
    opacity: 1;
  }

  @media (min-width: 1024px) {
    .kort-sektion {
      display: flex;
      flex-direction: column;
      align-items: center;
      max-width: 1440px;
      margin: 5rem auto 0;
      padding: 0 2rem;
      gap: 2rem;
    }

    .kort-header {
      width: 100%;
      text-align: left;
    }

    .kort-header h2,
    .kort-header p,
    .kort-header .filter-knapper {
      max-width: 50%;
    }

    h2 {
      font-size: 2.2rem;
    }

    p {
      font-size: 1rem;
    }

    .kort-container {
      width: 100%;
    }
  }
</style>

<script>
  import { createClient } from "@supabase/supabase-js";

  const supabase = createClient(import.meta.env.PUBLIC_SUPABASE_URL, import.meta.env.PUBLIC_SUPABASE_ANON_KEY);

  const svg = document.getElementById("danmarkskort") as unknown as SVGSVGElement;
  const prikkerGruppe = document.getElementById("natursted-prikker") as unknown as SVGGElement;
  const tooltip = document.getElementById("tooltip") as HTMLElement;
  const filterKnapper = document.querySelectorAll(".filter-knap");
  const regionPaths = document.querySelectorAll(".region-path");

  const zoomKoordinater: Record<string, string> = {
    alle: "0 0 1000 810",
    Nordjylland: "100 50 400 300",
    Midtjylland: "100 300 400 300",
    Syddanmark: "50 500 400 320",
    Sjælland: "380 450 400 320",
    Hovedstaden: "480 380 250 200",
  };

  function zoomTilRegion(region: string) {
    const viewBox = zoomKoordinater[region] || "0 0 1000 810";
    svg.style.transition = "all 0.6s ease";
    svg.setAttribute("viewBox", viewBox);
  }

  function tegnPrikker(steder: any[]) {
    prikkerGruppe.innerHTML = "";
    steder.forEach((sted) => {
      if (!sted.koordinat_x || !sted.koordinat_y) return;

      const cirkel = document.createElementNS("http://www.w3.org/2000/svg", "circle");
      cirkel.setAttribute("cx", String(sted.koordinat_x));
      cirkel.setAttribute("cy", String(sted.koordinat_y));
      cirkel.setAttribute("r", "10");
      cirkel.style.fill = "var(--solsikkegul-lys)";
      cirkel.style.stroke = "var(--solsikkegul-aktiv)";
      cirkel.setAttribute("stroke-width", "2");
      cirkel.classList.add("natursted-prik", "skjult");
      cirkel.dataset.region = sted.region;
      cirkel.dataset.titel = sted.titel;
      cirkel.dataset.slug = sted.slug;

      cirkel.addEventListener("touchstart", (e: TouchEvent) => {
        const touch = e.touches[0];
        tooltip.textContent = sted.titel;
        tooltip.classList.add("synlig");
        tooltip.style.left = touch.clientX + 12 + "px";
        tooltip.style.top = touch.clientY - 50 + "px";
        setTimeout(() => tooltip.classList.remove("synlig"), 2000);
      });

      cirkel.addEventListener("click", (e: MouseEvent) => {
        e.stopPropagation();
        window.location.href = `/natursted/${sted.slug}`;
      });

      prikkerGruppe.appendChild(cirkel);
    });
  }

  function filterPrikker(region: string) {
    document.querySelectorAll(".natursted-prik").forEach((prik: any) => {
      if (region === "alle") {
        prik.classList.add("skjult");
      } else if (prik.dataset.region === region) {
        prik.classList.remove("skjult");
      } else {
        prik.classList.add("skjult");
      }
    });
  }

  function opdaterRegioner(region: string) {
    regionPaths.forEach((path: any) => {
      if (region === "alle") {
        path.classList.remove("tonet", "aktiv-region");
      } else if (path.dataset.region === region) {
        path.classList.remove("tonet");
        path.classList.add("aktiv-region");
      } else {
        path.classList.remove("aktiv-region");
        path.classList.add("tonet");
      }
    });
  }

  filterKnapper.forEach((knap) => {
    knap.addEventListener("click", () => {
      filterKnapper.forEach((k) => k.classList.remove("aktiv"));
      knap.classList.add("aktiv");
      const region = (knap as HTMLElement).dataset.region || "alle";
      filterPrikker(region);
      opdaterRegioner(region);
      zoomTilRegion(region);
    });
  });

  regionPaths.forEach((path) => {
    path.addEventListener("click", () => {
      const region = (path as HTMLElement).dataset.region || "alle";
      filterKnapper.forEach((k) => k.classList.remove("aktiv"));
      const matchendeKnap = document.querySelector(`.filter-knap[data-region="${region}"]`);
      if (matchendeKnap) matchendeKnap.classList.add("aktiv");
      filterPrikker(region);
      opdaterRegioner(region);
      zoomTilRegion(region);
    });
  });

  async function init() {
    const { data, error } = await supabase.from("natursteder").select("titel, slug, region, koordinat_x, koordinat_y");

    if (error) {
      console.error("Supabase fejl:", error);
    } else {
      tegnPrikker(data);

      svg.addEventListener("mousemove", (e: MouseEvent) => {
        const element = document.elementFromPoint(e.clientX, e.clientY);
        if (element && element.classList.contains("natursted-prik")) {
          const titel = (element as HTMLElement).dataset.titel;
          tooltip.textContent = titel || "";
          tooltip.style.opacity = "1";
          tooltip.style.left = e.clientX + 12 + "px";
          tooltip.style.top = e.clientY - 30 + "px";
        } else {
          tooltip.style.opacity = "0";
        }
      });
    }
  }

  init();
</script>
