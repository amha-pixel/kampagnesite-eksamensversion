---
const partnere = [
  { navn: "Emmerys", indryk: 0.5 },
  { navn: "Fælleskassen", indryk: 2 },
  { navn: "Faster Oikos", indryk: 0 },
  { navn: "Flowering", indryk: 1.5 },
  { navn: "Genbyg", indryk: 0.8 },
  { navn: "Kirppu", indryk: 2.5 },
  { navn: "Loppesupermarked", indryk: 0.3 },
  { navn: "Løberen", indryk: 1.2 },
  { navn: "Lollands Bank", indryk: 2 },
  { navn: "Merkur Andelskasse", indryk: 0.5 },
  { navn: "RedMaden", indryk: 1.8 },
  { navn: "Rise Sparekasse", indryk: 0.2 },
  { navn: "Sport 24", indryk: 1 },
  { navn: "Sportigan", indryk: 2.2 },
];
---

<section class="partnerskaber" aria-labelledby="partnerskaber-titel">
  <div class="container">
    <div class="indhold">
      <div class="tekst">
        <img src="/images/collage/papir-fersken.webp" alt="" class="papir-fersken" aria-hidden="true" role="presentation" pointer-events="none" />
        <h2 id="partnerskaber-titel" class="partnerskaber-titel">Partnerskaber</h2>
        <p class="partnerskaber-tekst">
          En række danske butikker og banker har valgt at være med i Dankort Øremærket. Det betyder at de donerer 1 øre oveni Dankorts øre, hver gang du betaler med Dankort hos dem. To øre pr. betaling og stadig gratis for dig.
        </p>
      </div>

      <div class="post-it" role="complementary" aria-label="Liste over partnerbutikker og -banker">
        <p class="post-it-overskrift" aria-hidden="true">Partnerskaber</p>
        <ul aria-label="Partnere i Dankort Øremærket">
          {partnere.map((partner) => <li style={`padding-left: ${partner.indryk}rem`}>{partner.navn}</li>)}
        </ul>
        <p class="flere">Flere partnere på vej</p>
      </div>
    </div>
  </div>
</section>

<style>
  .partnerskaber {
    margin-top: 3rem;
    padding: 2rem 0;
  }

  .indhold {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .tekst {
    position: relative;
  }

  .papir-fersken {
    position: absolute;
    top: -40px;
    left: -20px;
    width: 60%;
    z-index: 0;
    pointer-events: none;
  }

  .partnerskaber-titel {
    position: relative;
    z-index: 1;
    font-size: 1.8rem;
    margin-bottom: 1rem;
  }

  .partnerskaber-tekst {
    position: relative;
    z-index: 1;
    font-size: 0.9rem;
    line-height: 1.6;
  }

  .post-it {
    font-family: var(--font-postit);
    background-color: var(--solsikkegul-lys);
    padding: 1.5rem 2rem;
    transform: rotate(1.5deg);
    box-shadow: 3px 3px 10px rgba(0, 0, 0, 0.12);
    align-self: flex-start;
    margin: 0 auto;
  }

  .post-it ul {
    list-style: none;
    padding: 0;
    line-height: 2;
    font-size: 1rem;
    color: var(--sort);
  }

  .post-it-overskrift {
    font-family: var(--font-postit);
    font-size: 1.4rem;
    font-weight: 400;
    margin-bottom: 0.5rem;
    text-align: center;
  }

  .flere {
    font-family: var(--font-postit);
    font-size: 0.85rem;
    margin-top: 0.5rem;
    opacity: 0.7;
  }

  @media (min-width: 1024px) {
    .partnerskaber {
      margin-top: 5rem;
      padding: 3rem 0;
    }

    .indhold {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0 3rem;
      align-items: center;
    }

    .papir-fersken {
      top: -100px;
      left: -50px;
      width: 60%;
    }

    .partnerskaber-titel {
      font-size: 2.2rem;
    }

    .partnerskaber-tekst {
      font-size: 1rem;
    }

    .post-it {
      justify-self: center;
      width: 80%;
    }
  }
</style>
