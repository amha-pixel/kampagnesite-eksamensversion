---
const spoergsmaal = [
  {
    spørgsmål: "Er det mine egne penge der doneres?",
    svar: "Nej. Dankort donerer selv 1 øre pr. betaling — ikke dig. Det koster dig ingenting ekstra.",
  },
  {
    spørgsmål: "Hvad er Den Danske Naturfond?",
    svar: "En privat fond stiftet i 2015, der køber, beskytter og genopretter natur i hele Danmark. De arbejder uafhængigt og har ingen særlige interesser. Pengene går ubeskåret til natur.",
  },
  {
    spørgsmål: "Opfordrer det til merforbrug?",
    svar: "Nej. Idéen er at vælge Dankort når du alligevel skal betale — ikke at bruge flere penge.",
  },
  {
    spørgsmål: "Hvad hvis jeg ikke vil støtte Naturfonden?",
    svar: "Så vælger du bare en anden betalingsform. Simpelt.",
  },
  {
    spørgsmål: "Kan jeg se hvilken natur mine betalinger støtter?",
    svar: "Ja. På Danmarkskortet kan du se alle de naturområder Dankort Øremærket har bidraget til — fra Falster til Jammerbugten.",
  },
  {
    spørgsmål: "Donerer butikkerne også?",
    svar: "Nogle gør. Partnere i Dankort Øremærket donerer 1 øre oveni Dankorts øre — så én betaling kan blive til 2 eller 3 øre.",
  },
  {
    spørgsmål: "Er der dyr i naturområderne?",
    svar: "Ja. Heste og kvæg afgræsser flere af områderne — det skaber mere mangfoldig natur. Naturfonden ejer ikke selv dyrene, men indgår aftaler med lokale dyreholdere.",
  },
  {
    spørgsmål: "Hvad gør Naturfonden konkret med pengene?",
    svar: "De lader vand flyde frit, fjerner invasive planter, forvandler marker til blomsterenge og lader gamle træer stå. Ingen fancy løsninger — bare mere vild natur.",
  },
  {
    spørgsmål: "Hvad er forskellen på Dankort og Visa/Mastercard?",
    svar: "Dankort er dansk, gratis at bruge og har gebyrer fastsat ved lov. Visa og Mastercard er internationale — og butikkerne betaler betydeligt mere for at modtage dem. Den regning ender til sidst i priserne på varerne.",
  },
  {
    spørgsmål: "Kan jeg bruge Dankort på mobilen?",
    svar: "Ja. Danske Bank tilbyder Dankort i Apple Pay. Bruger du en anden bank, betaler du sandsynligvis med Visa- eller Mastercard-delen af dit kort når du tapper med mobilen — selv hvis du tror du bruger Dankort.",
  },
];
---

<section class="faq">
  <div class="container">
    <h2>Det folk bliver ved med at spørge om</h2>
  </div>

  <div class="karrusel-wrapper">
    <div class="container">
      <div class="karrusel" id="karrusel">
        {
          spoergsmaal.map((item, i) => (
            <div class="card" data-index={i}>
              <div class="card-indre">
                <div class="forside">
                  <p>{item.spørgsmål}</p>
                </div>
                <div class="bagside">
                  <p>{item.svar}</p>
                </div>
              </div>
            </div>
          ))
        }
      </div>

      <div class="prikker" id="prikker">
        {spoergsmaal.map((_, i) => <button class="prik" data-index={i} aria-label={`Gå til kort ${i + 1}`} />)}
      </div>
    </div>
  </div>
</section>

<style>
  .faq {
    margin-top: 3rem;
  }

  h2 {
    font-size: 1.8rem;
    font-weight: 800;
    text-align: center;
    margin-bottom: 2rem;
    padding: 0 1rem;
  }

  .karrusel-wrapper {
    background-color: #ffd998;
    padding: 2rem 0 1.5rem;
  }

  .karrusel {
    display: flex;
    gap: 1rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding: 1rem 1.5rem;
  }

  .karrusel::-webkit-scrollbar {
    display: none;
  }

  .card {
    scroll-snap-align: center;
    flex: 0 0 75vw;
    max-width: 280px;
    height: 260px;
    perspective: 1000px;
    cursor: pointer;
  }

  .card-indre {
    position: relative;
    width: 100%;
    height: 100%;
    transition: transform 0.5s ease;
    transform-style: preserve-3d;
  }

  .card.aaben .card-indre {
    transform: rotateY(180deg);
  }

  .forside,
  .bagside {
    position: absolute;
    width: 100%;
    height: 100%;
    backface-visibility: hidden;
    background-color: #ffe8b6;
    border-radius: 0.75rem;
    padding: 1.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 2px 2px 8px rgba(0, 0, 0, 0.08);
  }

  .forside p {
    font-size: 1rem;
    font-weight: 700;
    text-align: center;
    line-height: 1.4;
  }

  .bagside {
    transform: rotateY(180deg);
  }

  .bagside p {
    font-size: 0.85rem;
    line-height: 1.5;
    text-align: center;
  }

  .prikker {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    padding: 1rem 0 0.5rem;
  }

  .prik {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: #ffe8b6;
    border: none;
    cursor: pointer;
    padding: 0;
    transition:
      background-color 0.2s ease,
      transform 0.2s ease;
  }

  .prik.aktiv {
    background-color: #c47f00;
    transform: scale(1.3);
  }

  h2 {
    font-size: 1.8rem;
    font-weight: 800;
    text-align: left;
    margin-bottom: 2rem;
    padding: 0 1rem;
  }

  @media (min-width: 1024px) {
    .faq {
      margin-top: 5rem;
    }

    h2 {
      font-size: 2.2rem;
    }

    .card {
      flex: 0 0 220px;
      max-width: 220px;
      height: 280px;
    }
  }
</style>

<script>
  const karrusel = document.getElementById("karrusel") as HTMLElement;
  const prikker = document.querySelectorAll(".prik");
  const cards = document.querySelectorAll(".card");

  // Flip kort ved klik
  cards.forEach((card) => {
    card.addEventListener("click", () => {
      card.classList.toggle("aaben");
    });
  });

  // Klik på prik scroller til kort
  prikker.forEach((prik, i) => {
    prik.addEventListener("click", () => {
      const card = cards[i] as HTMLElement;
      card.scrollIntoView({ behavior: "smooth", block: "nearest", inline: "center" });
    });
  });

  // Opdater aktiv prik ved scroll
  const opdaterPrik = () => {
    const midt = karrusel.scrollLeft + karrusel.offsetWidth / 2;
    let aktivIndex = 0;
    cards.forEach((card, i) => {
      const el = card as HTMLElement;
      const kortMidt = el.offsetLeft + el.offsetWidth / 2;
      if (Math.abs(kortMidt - midt) < Math.abs((cards[aktivIndex] as HTMLElement).offsetLeft + (cards[aktivIndex] as HTMLElement).offsetWidth / 2 - midt)) {
        aktivIndex = i;
      }
    });
    prikker.forEach((p, i) => {
      p.classList.toggle("aktiv", i === aktivIndex);
    });
  };

  karrusel.addEventListener("scroll", opdaterPrik);
  opdaterPrik();
</script>
