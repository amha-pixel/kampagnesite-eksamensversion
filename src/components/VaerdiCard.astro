---
interface Props {
  billede: string;
  billedeAlt: string;
  overskrift: string;
  underoverskrift: string;
  href: string;
}

const { billede, billedeAlt, overskrift, underoverskrift, href } = Astro.props;
---

<a href={href} class="kort slide-ned" aria-label={`Læs mere om ${overskrift} — ${underoverskrift}`}>
  <img src={billede} alt={billedeAlt} class="kort-billede" />
  <div class="kort-tekst">
    <div class="logo-og-titel">
      <img src="/images/ui/dankort-logo.svg" alt="" class="kort-logo" aria-hidden="true" role="presentation" />
      <p class="kort-overskrift" aria-hidden="true">{overskrift}</p>
    </div>
    <p class="kort-underoverskrift" aria-hidden="true">{underoverskrift}</p>
  </div>
</a>

<style>
  .kort {
    flex: 0 0 65vw;
    max-width: 260px;
    border-radius: 0.2rem;
    overflow: hidden;
    display: block;
    position: relative;
    scroll-snap-align: start;
  }

  .kort-billede {
    width: 100%;
    height: 380px;
    object-fit: cover;
    display: block;
  }

  .kort-tekst {
    position: absolute;
    top: 1.3rem;
    left: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .logo-og-titel {
    display: flex;
    flex-direction: row;
    align-items: flex-end;
    gap: 0;
  }

  .kort-logo {
    height: 40px;
    width: auto;
    flex-shrink: 0;
  }

  .kort-overskrift {
    font-family: var(--font-display);
    font-size: 2.5rem;
    color: var(--sort);
    line-height: 0.9;
    margin-left: -4px;
  }

  .kort-underoverskrift {
    font-family: var(--font-body);
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--sort);
    padding-left: 32px;
  }

  @keyframes ryst {
    0%   { transform: rotate(0deg); }
    25%  { transform: rotate(-2deg); }
    50%  { transform: rotate(2deg); }
    75%  { transform: rotate(-1deg); }
    100% { transform: rotate(0deg); }
  }

  .kort:hover {
    animation: ryst 0.4s ease;
  }
</style>