---
import CtaKnap from "./CtaKnap.astro";
---

<div class="vaerdi-filter">
  <div class="knap-raekke">
    <CtaKnap tekst="Tjek værdierne ud" id="vaerdi-knap" type="button" />
    <span class="valgt-vaerdi" id="valgt-vaerdi"></span>
  </div>
  <ul class="vaerdi-liste" id="vaerdi-liste">
    <li><a href="#natur">Natur</a></li>
    <li><a href="#lokalt">Lokalt</a></li>
    <li><a href="#socialt">Socialt</a></li>
    <li><a href="#faelles">Fællesskab</a></li>
  </ul>
</div>

<script>
  const vaerdiKnap = document.querySelector("#vaerdi-knap");
  const vaerdiListe = document.getElementById("vaerdi-liste");
  const valgtVaerdi = document.getElementById("valgt-vaerdi");

  vaerdiKnap?.addEventListener("click", () => {
    vaerdiListe?.classList.toggle("aaben");
  });

  vaerdiListe?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => {
      document.querySelectorAll(".vaerdi-sektion").forEach((s) => s.classList.add("skjult"));
      const maal = link.getAttribute("href");
      if (maal) {
        document.querySelector(maal)?.classList.remove("skjult");
      }
      if (valgtVaerdi) {
        valgtVaerdi.textContent = link.textContent;
      }
      vaerdiListe.classList.remove("aaben");
    });
  });
</script>

<style is:global>
  .vaerdi-filter {
    margin: 1.5rem 1.25rem;
    max-width: 320px;
  }

  .knap-raekke {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .vaerdi-liste {
    display: none;
    list-style: none;
    padding: 0.5rem 0;
    margin: 0;
  }

  .vaerdi-liste.aaben {
    display: block;
  }

  .vaerdi-liste li a {
    display: block;
    padding: 0.4rem 0;
    font-weight: 800;
    color: var(--sort);
    text-decoration: none;
    font-size: 0.95rem;
    border-bottom: 1px solid #e0e0e0;
  }

  .vaerdi-liste li a:hover {
    text-decoration: underline;
  }

  .valgt-vaerdi {
    font-weight: 800;
    color: var(--sort);
    font-size: 1.4rem;
  }
</style>
