---
import CtaKnap from "./CtaKnap.astro";

const vaerdier = [
  {
    slug: "natur",
    titel: "Når danskere betaler, vokser naturen",
    tekst: [
      "830.000 kvadratmeter ny vild natur om året. Ikke fordi nogen har doneret en stor check, men fordi danskere millioner af gange har købt dagligvarer, betalt husleje og hentet takeaway med Dankort. Det er det vildeste fællesskabsprojekt Danmark har set i lang tid.",
    ],
    billede: "/images/natursteder/natur-rapsmark.webp",
    billedeAlt: "Dansk natur",
  },
  {
    slug: "lokalt",
    titel: "Når du betaler lokalt, betaler du det videre",
    tekst: [
      "Din lokale butik er ikke ligeglad med hvilket kort du bruger. Dankort er det billigste betalingskort for butikkerne — gebyret er fastsat ved lov og betydeligt lavere end Visa og Mastercard. Bog & idé regnede det engang ud: hvis alle betalte med Dankort ville de spare 1,7 millioner kroner om året i gebyrer. De pengene ender ikke i et pengeskab — de ender i butikkens priser. Så når du swiper med Dankort hos din lokale bager, giver du ham faktisk en lille håndsrækning han aldrig ville bede dig om. Og de butikker der er partnere i Dankort Øremærket, donerer oven i købet en øre til dansk natur hver gang du handler hos dem.",
    ],
    billede: "/images/natursteder/lokalmiljoe-landsby.webp",
    billedeAlt: "Lokalt dansk miljø",
  },
  {
    slug: "socialt",
    titel: "DK's sociale betalingsfællesskab",
    tekst: [
      "De fedeste ting sker ikke fordi én person beslutter det. De sker fordi alle gør det. Dankort Øremærket er blevet en social bevægelse blandt unge danskere. Ikke fordi nogen har bedt dem om det — men fordi det giver mening. Og fordi Tobias Rahim synes det er fedt.",
    ],
    billede: "/images/natursteder/faellesskab-badebro.webp",
    billedeAlt: "Sociale fællesskaber",
  },
  {
    slug: "faelles",
    titel: "Den danske sommer tilhører alle, det gør naturen også",
    tekst: [
      "Bag hvert naturområde Dankort Øremærket har støttet ligger millioner af helt almindelige betalinger fra helt almindelige danskere. Det er ikke en stor handling — det er mange små. Og tilsammen er de noget ret særligt.",
      "Dankort Øremærket er ikke noget du melder dig ind i. Det er et fællesskab du er en del af, hver gang du betaler.",
    ],
    billede: "/images/natursteder/faellesskab-picnic.webp",
    billedeAlt: "Fællesskab i naturen",
  },
];
---

{
  vaerdier.map((v, index) => (
    <section class={`vaerdi-sektion ${index !== 0 ? "skjult" : ""}`} id={v.slug} aria-labelledby={`titel-${v.slug}`}>
      <div class="gul-blok">
        <h2 id={`titel-${v.slug}`}>{v.titel}</h2>
        {v.tekst.map((afsnit) => (
          <p class="desktop-tekst">{afsnit}</p>
        ))}
      </div>

      <div class="billede-wrapper">
        <img src={v.billede} alt={v.billedeAlt} class="vaerdi-billede" />
        <img src="/images/ui/dankort-icon.svg" alt="" class="dankort-overlay" aria-hidden="true" />
      </div>

      {v.tekst.map((afsnit) => (
        <p class="mobil-tekst">{afsnit}</p>
      ))}

      <div class="cta-omraade">
        <p class="cta-spoergsmaal">Vil du være en del af fællesskabet?</p>
        <div class="papirstykke-wrapper">
          <div class="knap-over-papir">
            <CtaKnap tekst="Sådan bestiller du Dankort" popupId="popup" />
          </div>
          <img src="/images/collage/papirstykke-sort.png" alt="" class="papirstykke" aria-hidden="true" />
        </div>
      </div>
    </section>
  ))
}

<style>
  .vaerdi-sektion {
    display: grid;
    grid-template-rows: auto auto auto auto;
    overflow: hidden;
    max-width: 1440px;
    margin: 0 auto;
    width: 100%;
  }

  .gul-blok {
    background-color: var(--solsikkegul-lys);
    padding: 2rem 1.25rem 4rem;
  }

  .gul-blok h2 {
    font-size: 2rem;
    line-height: 1.1;
    margin: 0;
  }

  .desktop-tekst {
    display: none;
  }

  .billede-wrapper {
    position: relative;
    margin-top: -2.5rem;
    margin-left: 1.25rem;

    max-width: 100%;
  }

  .vaerdi-billede {
    width: 100%;
    height: 260px;
    object-fit: cover;
    display: block;
    overflow: hidden;
  }

  .dankort-overlay {
    position: absolute;
    bottom: -3.2rem;
    left: -2.2rem;
    width: 200px;
    rotate: -6deg;
    filter: drop-shadow(0 4px 8px rgba(0, 0, 0, 0.3));
  }

  .mobil-tekst {
    font-size: 0.9rem;
    padding: 1.5rem 1.25rem 0;
  }

  .mobil-tekst + .mobil-tekst {
    padding-top: 0.5rem;
  }

  .cta-omraade {
    padding: 1.5rem 1.25rem 0;
  }

  .cta-spoergsmaal {
    font-size: 1.1rem;
    font-weight: 700;
    margin: 0 0 1rem;
  }

  .papirstykke-wrapper {
    position: relative;
    margin-left: -1.25rem;
  }

  .papirstykke {
    display: block;
    width: 100%;
    max-width: 450px;
    margin-top: -4rem;
    position: relative;
    z-index: 1;
  }

  .knap-over-papir {
    position: relative;
    z-index: 3;
    margin-left: 1.25rem;
    margin-bottom: 0.5rem;
  }

  .skjult {
    display: none;
  }

  .vaerdi-tekst + .vaerdi-tekst {
    margin-top: 1rem;
  }

  @media (min-width: 1024px) {
    .vaerdi-sektion {
      grid-template-columns: 1fr 1fr;
      grid-template-rows: auto auto;
      grid-template-areas:
        "gul     billede"
        "cta     billede";
      min-height: 420px;
    }

    .gul-blok {
      padding: 3.5rem 3rem 2rem;
    }

    .gul-blok h2 {
      font-size: 3rem;
    }

    .desktop-tekst {
      display: block;
      margin-top: 1.25rem;
    }

    .mobil-tekst {
      display: none;
    }

    .billede-wrapper {
      grid-area: billede;
      margin: -54px -54px 0 0;
    }

    .vaerdi-billede {
      height: 100%;
      min-height: 420px;
    }

    .dankort-overlay {
      bottom: 0;
      left: -11rem;
      width: 450px;
    }

    .cta-omraade {
      grid-area: cta;
      padding: 2rem 3rem 3rem;
      align-self: end;
    }

    .cta-spoergsmaal {
      font-size: 1.3rem;
    }

    .papirstykke {
      width: 500px;
    }
  }
</style>
