---
import Layout from "../components/Layout.astro";
import HeroSektion from "../components/HeroSektion.astro";
import VaerdiCard from "../components/VaerdiCard.astro";
import SpoergsmaalSektion from "../components/SpoergsmaalSektion.astro";
import BestilPopup from "../components/BestilPopup.astro";
import HvadErSektion from "../components/HvadErSektion.astro";
import SamarbejdsSektion from "../components/SamarbejdsSektion.astro";
import PartnerskabsSektion from "../components/PartnerskabsSektion.astro";
import QandASektion from "../components/QandASektion.astro";
---

<Layout title="Dankort Øremærket">
  <HeroSektion />
  <HvadErSektion />
  <SpoergsmaalSektion />
  <BestilPopup />
  

  <section class="karrusel-sektion">
    <div class="karrusel">
      <VaerdiCard billede="/images/natursteder/natur-rapsmark.webp" overskrift="Øremærket" underoverskrift="og naturen" href="/overblik#natur" />
      <VaerdiCard billede="/images/natursteder/lokalmiljoe-landsby.webp" overskrift="Øremærket" underoverskrift="og lokalmiljøet" href="/overblik#lokalt" />
      <VaerdiCard billede="/images/natursteder/faellesskab-badebro.webp" overskrift="Øremærket" underoverskrift="og det sociale" href="/overblik#socialt" />
      <VaerdiCard billede="/images/natursteder/faellesskab-picnic.webp" overskrift="Øremærket" underoverskrift="og fællesskabet" href="/overblik#faelles" />
    </div>
  </section>

  <SamarbejdsSektion />
  <PartnerskabsSektion />
  <QandASektion />
</Layout>

<style>

  .karrusel-sektion {
    padding: 2rem 0;
    overflow: hidden;
  }

  .karrusel {
    display: flex;
    gap: 1rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    padding: 0 1rem;
    -ms-overflow-style: none;
    scrollbar-width: none;
  }

  .karrusel::-webkit-scrollbar {
    display: none;
  }

  @media (min-width: 1024px) {
    .karrusel-sektion {
      max-width: 1440px;
      margin: 0 auto;
      padding: 2rem;
    }

    .karrusel {
      overflow-x: visible;
      justify-content: center;
      gap: 1rem;
    }
  }
</style>

