---
import Layout from "../components/Layout.astro";
import VaerdiCard from "../components/VaerdiCard.astro";
import SpoergsmaalSektion from "../components/SpoergsmaalSektion.astro";
import BestilPopup from "../components/BestilPopup.astro";
import HvadErSektion from "../components/HvadErSektion.astro";
import SamarbejdsSektion from "../components/SamarbejdsSektion.astro";
import PartnerskabsSektion from "../components/PartnerskabsSektion.astro";
import QandASektion from "../components/QandASektion.astro";
---

<Layout title="Dankort Øremærket">
  <section class="hero">
    <div class="video-wrapper">
      <video autoplay muted loop playsinline id="hero-video" class="hero-video">
        <source src="/video/hero.mp4" type="video/mp4" />
      </video>
      <h2 class="hero-tekst">Mød <span class="display">Øremærkets</span><br />ambassadør</h2>
      <button class="play-pause" id="play-pause" aria-label="Pause video">
        <span id="ikon">⏸</span>
      </button>
    </div>
  </section>

  <SpoergsmaalSektion />
  <BestilPopup />
  <HvadErSektion />

  <section class="karrusel-sektion">
    <div class="karrusel">
      <VaerdiCard billede="/images/natursteder/natur-rapsmark.webp" overskrift="Øremærket" underoverskrift="og naturen" href="/overblik#natur" />
      <VaerdiCard billede="/images/natursteder/lokalmiljoe-landsby.webp" overskrift="Øremærket" underoverskrift="og lokalmiljøet" href="/overblik#lokalt" />
      <VaerdiCard billede="/images/natursteder/faellesskab-badebro.webp" overskrift="Øremærket" underoverskrift="og det sociale" href="/overblik#socialt" />
      <VaerdiCard billede="/images/natursteder/faellesskab-picnic.webp" overskrift="Øremærket" underoverskrift="og fællesskabet" href="/overblik#faelles" />
    </div>
  </section>

  <SamarbejdsSektion />
  <PartnerskabsSektion />
  <QandASektion />
</Layout>

<style>
  .hero {
    display: flex;
    flex-direction: column;
  }

  .video-wrapper {
    position: relative;
    width: 100%;
    height: 80svh;
    min-height: 400px;
    background-color: var(--sort);
  }

  .hero-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .hero-tekst {
    position: absolute;
    top: 1.25rem;
    left: 1rem;
    font-size: 1.6rem;
    font-weight: 800;
    line-height: 1.2;
    color: var(--hvid);
    z-index: 1;
  }

  .hero-tekst :global(.display) {
    font-family: var(--font-display);
    font-weight: 400;
  }

  .play-pause {
    position: absolute;
    bottom: 50%;
    left: 50%;
    transform: translate(-50%, 50%);
    background: rgba(255, 255, 255, 0.2);
    border: 3px solid var(--hvid);
    border-radius: 50%;
    width: 56px;
    height: 56px;
    font-size: 1.4rem;
    color: var(--hvid);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    backdrop-filter: blur(4px);
  }

  .karrusel-sektion {
    padding: 2rem 0;
    overflow: hidden;
  }

  .karrusel {
    display: flex;
    gap: 1rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    padding: 0 1rem;
    -ms-overflow-style: none;
    scrollbar-width: none;
  }

  .karrusel::-webkit-scrollbar {
    display: none;
  }

  @media (min-width: 1024px) {
    .karrusel-sektion {
      max-width: 1440px;
      margin: 0 auto;
      padding: 2rem;
    }

    .karrusel {
      overflow-x: visible;
      justify-content: center;
      gap: 1rem;
    }
  }
</style>

<script>
  const video = document.getElementById("hero-video") as HTMLVideoElement;
  const knap = document.getElementById("play-pause");
  const ikon = document.getElementById("ikon");

  knap?.addEventListener("click", () => {
    if (video.paused) {
      video.play();
      if (ikon) ikon.textContent = "⏸";
    } else {
      video.pause();
      if (ikon) ikon.textContent = "▶";
    }
  });
</script>
