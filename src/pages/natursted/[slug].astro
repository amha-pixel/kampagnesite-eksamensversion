---
import Layout from "../../components/Layout.astro";
import Accordeon from "../../components/Accordeon.astro";
import { supabase } from "../../lib/supabase.js";

export async function getStaticPaths() {
  const { data, error } = await supabase.from("natursteder").select("slug");
  if (error) {
    console.log(error);
    return [];
  }
  return data.map((natursted) => ({
    params: { slug: natursted.slug },
  }));
}

const { slug } = Astro.params;
const { data, error } = await supabase.from("natursteder").select("*").eq("slug", slug).single();
---

<Layout title={data.titel} description={data.underrubrik}>
  <main class="side-grid container">
    <div class="venstre">
      <section class="hero" aria-labelledby="natursted-titel">
        <h1 id="natursted-titel">{data.titel}</h1>
        <p class="underrubrik">{data.underrubrik}</p>
      </section>

      <section class="brodtekst" aria-label="Beskrivelse">
        <p>{data.brodtekst}</p>
      </section>
    </div>

    <div class="hoejre">
      <section class="billede-sektion" aria-label="Billede af naturstedet">
        <div class="gul-firkant" aria-hidden="true"></div>
        <img src={data.billede} alt={`Naturstedet ${data.titel}`} class="naturbillede" fetchpriority="high" />
      </section>

      <section class="fakta" aria-label="Faktaboks">
        <h2>Fakta</h2>
        <p><strong>Natur</strong><br />{data.natur_fakta}</p>
        <p><strong>Areal</strong><br />{data.areal}</p>
        <p><strong>Økonomi</strong><br />{data.oekonomi}</p>
        <p><strong>Partnere</strong><br />{data.partnere}</p>
      </section>
    </div>

    <section class="accordeon" aria-label="Læs mere om naturstedet">
      <Accordeon titel="Opdag den unikke natur" indhold={data.unik_natur} />
      <Accordeon titel="Sådan hjælper vi naturen" indhold={data.dankort_hjaelper} />
      <Accordeon titel="Læs om naturoplevelserne" indhold={data.naturoplevelser} />
    </section>

    <a href="/overblik" class="tilbage-knap" aria-label="Tilbage til Danmarkskortet">
      <img src="/images/ui/pil-tilbage.svg" alt="" aria-hidden="true" />
    </a>
  </main>
</Layout>

<style>
  .hero {
    background-image: url("/images/collage/papirstykke-beige.png");
    background-size: 70%;
    background-repeat: no-repeat;
    background-position: -80px -20px;
    padding: 2rem 1rem 2rem;
  }

  .underrubrik {
    font-size: 1.3rem;
    font-weight: 400;
    line-height: 1.4;
  }

  .brodtekst {
    padding: 1.5rem 1rem 3rem;
  }

  .billede-sektion {
    position: relative;
    margin: 0 1rem 2rem;
    max-width: 90%;
  }

  .gul-firkant {
    position: absolute;
    top: -35px;
    right: -30px;
    width: 80%;
    height: 80%;
    background-color: var(--solsikkegul-mork);
    z-index: 0;
  }

  .naturbillede {
    position: relative;
    width: 100%;
    aspect-ratio: 4/3;
    object-fit: cover;
    z-index: 1;
  }

  .fakta {
    background-image: url("/images/collage/papir-fersken.png");
    background-size: 80%;
    background-position: -120px -35px;
    background-repeat: no-repeat;
    padding: 1.5rem 1rem;
    margin-top: 2rem;
  }

  .fakta p {
    font-size: 0.9rem;
    margin-bottom: 0.5rem;
  }

  .accordeon {
    padding: 1.5rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    align-items: flex-start;
  }

  .tilbage-knap {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin: 1rem 1rem 3rem;
    font-weight: 600;
    font-size: 0.9rem;
  }

  .tilbage-knap img {
    height: 100px;
  }

  @media (min-width: 600px) and (max-width: 1023px) {
    .hero {
      background-size: 45%;
      background-position: -20px -10px;
      padding: 2rem 1rem 5rem;
    }
  }

  @media (min-width: 1024px) {
    .side-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      grid-template-rows: auto auto auto;
      gap: 2rem;
      padding: 2rem;
      align-items: start;
    }

    .hero {
      background-size: 45%;
      background-position: -10px -10px;
      padding: 2rem 0 1rem 0;
    }

    .brodtekst {
      padding: 0;
    }

    .venstre {
      grid-column: 1 / 2;
      grid-row: 1;
      padding-left: 1rem;
      padding-top: 2rem;
    }

    .hoejre {
      grid-column: 2 / 3;
      grid-row: 1 / 4;
      display: flex;
      flex-direction: column;
    }

    .accordeon {
      grid-column: 1 / 2;
      grid-row: 2;
    }

    .tilbage-knap {
      grid-column: 1 / 2;
      grid-row: 3;
    }

    .gul-firkant {
      top: 100px;
      right: -53px;
    }

    .fakta {
      background-size: 45%;
      background-position: -20px -30px;
    }
  }
</style>
